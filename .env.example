# ── UYGULAMA ─────────────────────────────
NODE_ENV=development
PORT=3000

# ── VERİTABANI ───────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=shuttlepay
DB_USER=postgres
DB_PASSWORD=your_password_here

# ── JWT ──────────────────────────────────
JWT_SECRET=shuttlepay_super_secret_key_change_in_production
JWT_EXPIRES_IN=7d

# ── CLAUDE AI ────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your_key_here

# ── İYZİCO ÖDEME ─────────────────────────
IYZICO_API_KEY=your_iyzico_api_key
IYZICO_SECRET_KEY=your_iyzico_secret_key
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# ── GÜVENLİK ─────────────────────────────
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
